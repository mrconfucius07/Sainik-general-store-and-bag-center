# ---- Database (any Postgres works: local, Neon, Supabase pooler URL, RDS) ----
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ---- Store settings ----
NEXT_PUBLIC_STORE_NAME="Sainik General Store & Bag Center"
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# ---- Seed-time admin account (used by scripts/seed.ts) ----
ADMIN_EMAIL=admin@sainikstore.com
ADMIN_PASSWORD=sainik2025

# ---- Razorpay (get from https://dashboard.razorpay.com → Settings → API Keys) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ---- Email notifications (any SMTP: Zoho, Gmail app-password, Brevo, etc.) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_NOTIFY_EMAIL=orders@sainikstore.com

# ---- WhatsApp Cloud API notifications (Meta for Developers → WhatsApp) ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
ADMIN_WHATSAPP_NUMBER=
